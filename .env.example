HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
# BASE_PATH=/mcp/human-delegation
DATABASE_PATH=./data/delegate-to-human.db
ATTACHMENT_DIR=./data/attachments
TOKEN_SECRET=replace-with-at-least-32-random-bytes
ENCRYPTION_KEY=replace-with-32-byte-base64-key
ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Optional SMTP channel
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Delegate to Human <noreply@example.com>

# Optional Telegram channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Limits
MAX_ATTACHMENT_FILES=5
MAX_ATTACHMENT_TOTAL_BYTES=10485760
SIGNED_LINK_TTL_SECONDS=604800
DEADLINE_POLL_INTERVAL_MS=30000
